# Copy this file to .env for local development (docker-compose reads it
# automatically). On Render/Koyeb, set these as real environment variables
# in the dashboard instead — don't upload a .env file.

# --- Telegram bot ---
BOT_TOKEN=123456789:AAExampleTokenFromBotFather
# Any random string — used to keep /webhook/<secret> unguessable
WEBHOOK_SECRET=change-me-to-something-random
# Public HTTPS URL of this deployment once it's live, e.g.
# https://anime-index.onrender.com or https://anime-index-yourorg.koyeb.app
WEBAPP_URL=
# Channel/group ID the bot posts request + report notifications to.
# Add the bot to that channel as admin first, then grab its ID (starts with -100...)
LOG_CHANNEL_ID=
# Comma-separated Telegram user IDs allowed to run /addpost, /delpost, and
# edit join links from the mini app
ADMIN_IDS=

# --- Telegram API (MTProto — from https://my.telegram.org, optional) ---
# Not used by the current code. Reserved for a future feature (e.g.
# verifying a join link actually resolves to a real channel via
# Pyrogram/Telethon) — safe to leave blank for now.
API_ID=
API_HASH=

# --- Branding ---
BRAND_NAME=Anime Index
BRAND_HANDLE=ANIME_INDEX
BANNER_IMAGE_URL=
# Custom /anidex welcome message. Supports {first_name} and {brand_name}
# placeholders, Telegram Markdown formatting, and literal "\n" for line
# breaks (env vars can't contain real newlines). Leave unset to use the
# built-in default in config.py.
START_MSG=

# --- App ---
SECRET_KEY=change-me
PORT=8000
DEBUG=false
CATALOG_CACHE_TTL=600
# How long (seconds) the News tab's Spotlight story is cached before re-fetching
NEWS_CACHE_TTL=900

# --- Database (MongoDB) ---
# Local dev default works with `docker compose up` (see mongo service below).
# For production, use a connection string from MongoDB Atlas or similar,
# e.g. mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
MONGODB_NAME=anime_index
